"onboarding.title" = "Tere tulemast numbrile Navi Live";
"onboarding.section.intro" = "Lühijuhend";
"onboarding.intro" = "Navi Live on juurdepääsetav jalgsi navigeerimine. See õpetus näitab põhilist voolu: otsige sihtkohta, kontrollige marsruuti ja järgige kõndimise ajal hääljuhiseid.";
"onboarding.section.features" = "Põhivoog";
"onboarding.feature.search" = "Kasutage valikut Otsi sihtkohta ja tippige aadress või koht. Kui numbril Navi Live on teie asukoht, kuvatakse esmalt lähedalasuvad punktid.";
"onboarding.feature.route" = "Enne kõndimist kontrollige marsruudi eelvaadet ja veenduge, et juhiste loend on mõistlik.";
"onboarding.feature.navigation" = "Käivitage juhendamine ja kuulake vahemaa loendurit, pöördeid, ülekäigumärguandeid, helisid ja vibratsiooni.";
"onboarding.section.on_route" = "Teel";
"onboarding.feature.actions" = "Avage seaded mis tahes ekraanil, kasutage VoiceOveri rootori toiminguid kohtades ja raputage telefoni, et praegust juhist korrata.";
"onboarding.feature.accessibility" = "Kasutage iPhone'i loomulikke juhtnuppe, mis on loodud usaldusväärse VoiceOveri teravustamise jaoks.";
"onboarding.feature.favorites" = "Salvestage praegune asukoht oma nime all ja naaske selle juurde hiljem lemmikute hulgast.";
"onboarding.feature.safety" = "GPS-i ja kaardiandmed võivad olla ebatäiuslikud. Käsitle numbrit Navi Live kui toetust ja kontrolli alati ülekäiguradasid, liiklust ja ümbrust.";
"onboarding.action.start" = "Jätkake õigustega";
"onboarding.footer" = "Saate selle õpetuse hiljem uuesti avada menüüs Seaded.";
"permissions.title" = "Juurdepääs asukohale";
"permissions.status.title" = "Vajalik asukohaluba";
"permissions.status.message" = "Lubage juurdepääs asukohale, et Navi Live saaks leida läheduses olevaid kohti ja koostada jalutusmarsruute teie praegusest asukohast.";
"permissions.action.allow" = "Luba juurdepääs asukohale";
"permissions.action.later" = "Jätka praegu";
"permissions.footer" = "Saate asukoha juurdepääsu hiljem muuta iPhone'i seadetes.";
