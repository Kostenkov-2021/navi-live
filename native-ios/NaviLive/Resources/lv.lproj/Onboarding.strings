"onboarding.intro" = "Navi Live ir pieejama gājēju navigācija. Šajā apmācībā ir parādīta pamata plūsma: meklējiet galamērķi, pārbaudiet maršrutu, pēc tam sekojiet balss norādījumiem, ejot.";
"onboarding.section.features" = "Pamatplūsma";
"onboarding.feature.search" = "Izmantojiet Meklēt galamērķi un ierakstiet adresi vai vietu. Kad Navi Live ir jūsu atrašanās vieta, vispirms tiek parādīti tuvumā esošie punkti.";
"onboarding.feature.route" = "Pirms došanās kājām pārbaudiet maršruta priekšskatījumu un pārliecinieties, vai norādījumu saraksts ir jēgpilns.";
"onboarding.feature.navigation" = "Sāciet norādījumus un klausieties attāluma atpakaļskaitīšanu, pagriezienus, brīdinājumus par šķērsošanu, skaņas un vibrāciju.";
"onboarding.section.on_route" = "Pa ceļam";
"onboarding.feature.actions" = "Atveriet iestatījumus jebkurā ekrānā, izmantojiet VoiceOver rotora darbības vietās un pakratiet tālruni, lai atkārtotu pašreizējo norādījumu.";
"onboarding.feature.accessibility" = "Izmantojiet sākotnējās iPhone vadīklas, kas paredzētas uzticamam VoiceOver fokusam.";
"onboarding.feature.favorites" = "Saglabājiet pašreizējo pozīciju ar savu vārdu un atgriezieties tajā vēlāk no izlases.";
"onboarding.feature.safety" = "GPS un kartes dati var būt nepilnīgi. Uztveriet numuru Navi Live kā atbalstu un vienmēr pārbaudiet krustojumus, satiksmi un apkārtni.";
"onboarding.action.start" = "Pāriet uz atļaujām";
"onboarding.footer" = "Šo apmācību vēlāk varat atkārtoti atvērt sadaļā Iestatījumi.";
