"permissions.status.message" = "Atļaujiet piekļuvi atrašanās vietai, lai Navi Live varētu atrast tuvumā esošās vietas un sagatavot pastaigu maršrutus no jūsu pašreizējās atrašanās vietas.";
"permissions.action.allow" = "Atļaut piekļuvi atrašanās vietai";
