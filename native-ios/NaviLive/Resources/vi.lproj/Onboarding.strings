"permissions.status.message" = "Cho phép truy cập vị trí để Navi Live có thể tìm các địa điểm lân cận và chuẩn bị các tuyến đường đi bộ từ vị trí hiện tại của bạn.";
"permissions.action.allow" = "Cho phép truy cập vị trí";
