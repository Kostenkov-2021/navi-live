"onboarding.title" = "Chào mừng bạn đến với Navi Live";
"onboarding.section.intro" = "Hướng dẫn ngắn";
"onboarding.intro" = "Navi Live có thể truy cập điều hướng đi bộ. Hướng dẫn này trình bày quy trình cơ bản: tìm kiếm điểm đến, kiểm tra tuyến đường, sau đó làm theo hướng dẫn bằng giọng nói trong khi đi bộ.";
"onboarding.section.features" = "Luồng cơ bản";
"onboarding.feature.search" = "Sử dụng Tìm kiếm đích và nhập địa chỉ hoặc địa điểm. Khi Navi Live có vị trí của bạn, các điểm lân cận sẽ được hiển thị đầu tiên.";
"onboarding.feature.route" = "Kiểm tra bản xem trước tuyến đường trước khi đi bộ và đảm bảo danh sách hướng dẫn có ý nghĩa.";
"onboarding.feature.navigation" = "Bắt đầu hướng dẫn và lắng nghe đếm ngược khoảng cách, rẽ, cảnh báo băng qua, âm thanh và độ rung.";
"onboarding.section.on_route" = "Đang di chuyển";
"onboarding.feature.actions" = "Mở Cài đặt từ bất kỳ màn hình nào, sử dụng các tác vụ của rôto VoiceOver ở các địa điểm và lắc điện thoại để lặp lại hướng dẫn hiện tại.";
"onboarding.feature.accessibility" = "Sử dụng các điều khiển gốc của iPhone được thiết kế để lấy nét VoiceOver đáng tin cậy.";
"onboarding.feature.favorites" = "Lưu vị trí hiện tại dưới tên của chính bạn và quay lại vị trí đó sau từ Mục ưa thích.";
"onboarding.feature.safety" = "Dữ liệu bản đồ và GPS có thể không hoàn hảo. Hãy coi Navi Live là người hỗ trợ và luôn xác minh các lối đi qua, giao thông và khu vực xung quanh.";
"onboarding.action.start" = "Tiếp tục với các quyền";
"onboarding.footer" = "Bạn có thể mở lại hướng dẫn này sau từ Cài đặt.";
