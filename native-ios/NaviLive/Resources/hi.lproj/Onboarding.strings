"onboarding.title" = "Navi Live";
"onboarding.section.intro" = "में आपका स्वागत है लघु गाइड";
"onboarding.intro" = "Navi Live पैदल नेविगेशन तक पहुंच योग्य है। यह ट्यूटोरियल मूल प्रवाह दिखाता है: किसी गंतव्य की खोज करें, मार्ग की जांच करें, फिर चलते समय मौखिक मार्गदर्शन का पालन करें।";
"onboarding.section.features" = "मूल प्रवाह";
"onboarding.feature.search" = "खोज गंतव्य का उपयोग करें और एक पता या स्थान टाइप करें। जब Navi Live पर आपका स्थान होता है, तो आस-पास के बिंदु पहले दिखाए जाते हैं।";
"onboarding.feature.route" = "चलने से पहले मार्ग पूर्वावलोकन की जाँच करें और सुनिश्चित करें कि निर्देश सूची समझ में आती है।";
"onboarding.feature.navigation" = "मार्गदर्शन शुरू करें और दूरी की उलटी गिनती, मोड़, क्रॉसिंग अलर्ट, ध्वनियां और कंपन सुनें।";
"onboarding.section.on_route" = "रास्ते में";
"onboarding.feature.actions" = "किसी भी स्क्रीन से सेटिंग्स खोलें, स्थानों पर वॉयसओवर रोटर क्रियाओं का उपयोग करें, और वर्तमान निर्देश को दोहराने के लिए फोन को हिलाएं।";
"onboarding.feature.accessibility" = "विश्वसनीय वॉयसओवर फोकस के लिए डिज़ाइन किए गए देशी iPhone नियंत्रणों का उपयोग करें।";
"onboarding.feature.favorites" = "वर्तमान स्थिति को अपने नाम से सहेजें और बाद में पसंदीदा से इस पर वापस लौटें।";
"onboarding.feature.safety" = "जीपीएस और मानचित्र डेटा अपूर्ण हो सकता है। Navi Live को सहायता मानें और हमेशा क्रॉसिंग, यातायात और आसपास का सत्यापन करें।";
"onboarding.action.start" = "अनुमतियाँ जारी रखें";
"onboarding.footer" = "आप बाद में सेटिंग्स से इस ट्यूटोरियल को फिर से खोल सकते हैं।";
"permissions.title" = "स्थान पहुंच";
"permissions.status.title" = "स्थान अनुमति की आवश्यकता है";
"permissions.status.message" = "स्थान पहुंच की अनुमति दें ताकि Navi Live आस-पास के स्थानों को ढूंढ सकें और अपनी वर्तमान स्थिति से पैदल मार्ग तैयार कर सकें।";
"permissions.action.allow" = "स्थान पहुंच की अनुमति दें";
"permissions.action.later" = "अभी जारी रखें";
"permissions.footer" = "आप बाद में iPhone सेटिंग्स में स्थान पहुंच बदल सकते हैं।";
