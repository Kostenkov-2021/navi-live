"onboarding.title" = "Bienvenido a Navi Live";
"onboarding.section.intro" = "Guía breve";
"onboarding.intro" = "Navi Live es una navegación accesible para caminar. Este tutorial muestra el flujo básico: busque un destino, verifique la ruta y luego siga las instrucciones habladas mientras camina.";
"onboarding.section.features" = "Flujo básico";
"onboarding.feature.search" = "Utilice Buscar destino y escriba una dirección o lugar. Cuando Navi Live tiene tu ubicación, los puntos cercanos se muestran primero.";
"onboarding.feature.route" = "Consulta la vista previa de la ruta antes de caminar y asegúrate de que la lista de instrucciones tiene sentido.";
"onboarding.feature.navigation" = "Inicia la guía y escucha cuentas regresivas de distancia, giros, alertas de cruce, sonidos y vibraciones.";
"onboarding.section.on_route" = "En camino";
"onboarding.feature.actions" = "Abra Configuración desde cualquier pantalla, use las acciones del rotor de VoiceOver en algunos lugares y agite el teléfono para repetir la instrucción actual.";
"onboarding.feature.accessibility" = "Utilice controles nativos de iPhone diseñados para un enfoque confiable de VoiceOver.";
"onboarding.feature.favorites" = "Guarde la posición actual con su propio nombre y vuelva a ella más tarde desde Favoritos.";
"onboarding.feature.safety" = "Los datos de GPS y mapas pueden ser imperfectos. Tratar al Navi Live como apoyo y verificar siempre cruces, tránsito y alrededores.";
"onboarding.action.start" = "Continuar con permisos";
"onboarding.footer" = "Puede volver a abrir este tutorial más tarde desde Configuración.";
"permissions.title" = "Acceso a la ubicación";
"permissions.status.title" = "Se necesita permiso de ubicación";
"permissions.status.message" = "Permitir el acceso a la ubicación para que Navi Live pueda encontrar lugares cercanos y preparar rutas para caminar desde su posición actual.";
"permissions.action.allow" = "Permitir acceso a la ubicación";
"permissions.action.later" = "Continuar por ahora";
"permissions.footer" = "Puede cambiar el acceso a la ubicación más tarde en la configuración del iPhone.";
