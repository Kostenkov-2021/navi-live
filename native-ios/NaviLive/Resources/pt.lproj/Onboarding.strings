"onboarding.title" = "Bem-vindo ao Navi Live";
"onboarding.section.intro" = "Guia resumido";
"onboarding.intro" = "Navi Live é uma navegação a pé acessível. Este tutorial mostra o fluxo básico: procure um destino, verifique a rota e siga as orientações faladas enquanto caminha.";
"onboarding.section.features" = "Fluxo básico";
"onboarding.feature.search" = "Utilize Pesquisar destino e digite um endereço ou local. Quando Navi Live tiver sua localização, os pontos próximos serão mostrados primeiro.";
"onboarding.feature.route" = "Verifique a pré-visualização do percurso antes de caminhar e certifique-se de que a lista de instruções faz sentido.";
"onboarding.feature.navigation" = "Inicie a orientação e ouça contagens regressivas de distância, curvas, alertas de cruzamento, sons e vibrações.";
"onboarding.section.on_route" = "A caminho";
"onboarding.feature.actions" = "Abra Configurações em qualquer tela, use as ações do rotor do VoiceOver em lugares e agite o telefone para repetir a instrução atual.";
"onboarding.feature.accessibility" = "Use controles nativos do iPhone projetados para foco confiável do VoiceOver.";
"onboarding.feature.favorites" = "Salve a posição atual com seu próprio nome e retorne a ela mais tarde em Favoritos.";
"onboarding.feature.safety" = "Os dados do GPS e do mapa podem ser imperfeitos. Trate o Navi Live como apoio e verifique sempre cruzamentos, trânsito e arredores.";
"onboarding.action.start" = "Continuar para as permissões";
"onboarding.footer" = "Você pode reabrir este tutorial mais tarde em Configurações.";
"permissions.title" = "Acesso ao local";
"permissions.status.title" = "É necessária permissão de local";
"permissions.status.message" = "Permitir acesso ao local para que Navi Live possa encontrar lugares próximos e preparar percursos pedestres a partir da sua posição atual.";
"permissions.action.allow" = "Permitir acesso à localização";
"permissions.action.later" = "Continuar por enquanto";
"permissions.footer" = "Você pode alterar o acesso à localização posteriormente nas Configurações do iPhone.";
