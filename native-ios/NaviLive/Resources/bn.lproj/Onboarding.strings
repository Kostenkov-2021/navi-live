"onboarding.title" = "স্বাগতম Navi Live";
"onboarding.section.intro" = "সংক্ষিপ্ত গাইড";
"onboarding.intro" = "Navi Live অ্যাক্সেসযোগ্য হাঁটা নেভিগেশন। এই টিউটোরিয়ালটি মৌলিক প্রবাহ দেখায়: একটি গন্তব্য অনুসন্ধান করুন, রুট পরীক্ষা করুন, তারপর হাঁটার সময় কথ্য নির্দেশিকা অনুসরণ করুন।";
"onboarding.section.features" = "মৌলিক প্রবাহ";
"onboarding.feature.search" = "অনুসন্ধান গন্তব্য ব্যবহার করুন এবং একটি ঠিকানা বা স্থান টাইপ করুন। Navi Live এ আপনার অবস্থান থাকলে, কাছাকাছি পয়েন্টগুলি প্রথমে দেখানো হয়।";
"onboarding.feature.route" = "হাঁটার আগে রুট প্রিভিউ চেক করুন এবং নিশ্চিত করুন যে নির্দেশ তালিকাটি অর্থপূর্ণ।";
"onboarding.feature.navigation" = "নির্দেশিকা শুরু করুন এবং দূরত্বের কাউন্টডাউন, বাঁক, ক্রসিং সতর্কতা, শব্দ এবং কম্পনের জন্য শুনুন।";
"onboarding.section.on_route" = "পথে";
"onboarding.feature.actions" = "যেকোন স্ক্রীন থেকে সেটিংস খুলুন, জায়গায় ভয়েসওভার রটার অ্যাকশন ব্যবহার করুন এবং বর্তমান নির্দেশের পুনরাবৃত্তি করতে ফোনটি ঝাঁকান।";
"onboarding.feature.accessibility" = "নির্ভরযোগ্য ভয়েসওভার ফোকাসের জন্য ডিজাইন করা নেটিভ আইফোন নিয়ন্ত্রণ ব্যবহার করুন।";
"onboarding.feature.favorites" = "আপনার নিজের নামে বর্তমান অবস্থান সংরক্ষণ করুন এবং পছন্দসই থেকে পরে এটিতে ফিরে যান।";
"onboarding.feature.safety" = "GPS এবং মানচিত্রের ডেটা অসম্পূর্ণ হতে পারে। Navi Live কে সমর্থন হিসাবে বিবেচনা করুন এবং সর্বদা ক্রসিং, ট্র্যাফিক এবং আশপাশ যাচাই করুন।";
"onboarding.action.start" = "অনুমতিতে চালিয়ে যান";
"onboarding.footer" = "আপনি সেটিংস থেকে পরে এই টিউটোরিয়ালটি পুনরায় খুলতে পারেন।";
