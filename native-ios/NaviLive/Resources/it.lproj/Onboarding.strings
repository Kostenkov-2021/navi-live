"onboarding.title" = "Benvenuti al Navi Live";
"onboarding.section.intro" = "Breve guida";
"onboarding.intro" = "Navi Live è accessibile con navigazione a piedi. Questo tutorial mostra il flusso di base: cercare una destinazione, controllare il percorso, quindi seguire la guida vocale mentre si cammina.";
"onboarding.section.features" = "Flusso di base";
"onboarding.feature.search" = "Utilizza Cerca destinazione e digita un indirizzo o un luogo. Quando Navi Live rileva la tua posizione, vengono visualizzati per primi i punti vicini.";
"onboarding.feature.route" = "Controlla l'anteprima del percorso prima di camminare e assicurati che l'elenco delle istruzioni abbia senso.";
"onboarding.feature.navigation" = "Avvia la guida e ascolta il conto alla rovescia della distanza, le svolte, gli avvisi di attraversamento, i suoni e le vibrazioni.";
"onboarding.section.on_route" = "Sulla strada";
"onboarding.feature.actions" = "Apri Impostazioni da qualsiasi schermata, utilizza le azioni del rotore di VoiceOver sui luoghi e scuoti il ​​telefono per ripetere l'istruzione corrente.";
"onboarding.feature.accessibility" = "Utilizza i controlli nativi dell'iPhone progettati per un focus affidabile su VoiceOver.";
"onboarding.feature.favorites" = "Salva la posizione corrente con il tuo nome e ritornaci successivamente dai Preferiti.";
"onboarding.feature.safety" = "I dati GPS e cartografici possono essere imperfetti. Trattate il numero Navi Live come supporto e verificate sempre gli incroci, il traffico e i dintorni.";
"onboarding.action.start" = "Continua con le autorizzazioni";
"onboarding.footer" = "Puoi riaprire questo tutorial in un secondo momento da Impostazioni.";
"permissions.title" = "Accesso alla posizione";
"permissions.status.title" = "È necessaria l'autorizzazione alla posizione";
"permissions.status.message" = "Consenti l'accesso alla posizione in modo che Navi Live possa trovare luoghi nelle vicinanze e preparare percorsi pedonali dalla tua posizione attuale.";
"permissions.action.allow" = "Consenti l'accesso alla posizione";
"permissions.action.later" = "Continua per ora";
"permissions.footer" = "Puoi modificare l'accesso alla posizione in un secondo momento nelle Impostazioni dell'iPhone.";
