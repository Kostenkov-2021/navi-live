"onboarding.title" = "Sveiki atvykę į Navi Live";
"onboarding.section.intro" = "Trumpas vadovas";
"onboarding.intro" = "Navi Live yra pasiekiama navigacija pėsčiomis. Šioje pamokoje parodytas pagrindinis eiga: ieškokite tikslo, patikrinkite maršrutą, tada eidami vadovaukitės žodiniais nurodymais.";
"onboarding.section.features" = "Pagrindinis srautas";
"onboarding.feature.search" = "Naudokite Ieškoti paskirties vietos ir įveskite adresą arba vietą. Kai Navi Live nurodo jūsų vietą, pirmiausia rodomi netoliese esantys taškai.";
"onboarding.feature.route" = "Prieš eidami patikrinkite maršruto peržiūrą ir įsitikinkite, kad instrukcijų sąrašas yra prasmingas.";
"onboarding.feature.navigation" = "Pradėkite nurodymus ir klausykite atstumo skaičiavimų, posūkių, perspėjimų, garsų ir vibracijos.";
"onboarding.section.on_route" = "Pakeliui";
"onboarding.feature.actions" = "Bet kuriame ekrane atidarykite nustatymus, naudokite VoiceOver rotoriaus veiksmus vietose ir purtykite telefoną, kad pakartotumėte esamą instrukciją.";
"onboarding.feature.accessibility" = "Naudokite vietinius iPhone valdiklius, sukurtus patikimam VoiceOver fokusavimui.";
"onboarding.feature.favorites" = "Išsaugokite dabartinę poziciją savo vardu ir grįžkite į ją vėliau iš Parankinių.";
"onboarding.feature.safety" = "GPS ir žemėlapio duomenys gali būti netobuli. Laikykite Navi Live kaip paramą ir visada patikrinkite perėjas, eismą ir aplinką.";
"onboarding.action.start" = "Tęsti prie leidimų";
"onboarding.footer" = "Galite iš naujo atidaryti šią mokymo programą vėliau nustatymuose.";
"permissions.title" = "Vietos prieiga";
"permissions.status.title" = "Reikalingas vietos leidimas";
"permissions.status.message" = "Leiskite pasiekti vietą, kad Navi Live galėtų rasti netoliese esančias vietas ir parengti pėsčiųjų maršrutus iš jūsų dabartinės padėties.";
"permissions.action.allow" = "Leisti prieigą prie vietos";
"permissions.action.later" = "Tęsti dabar";
"permissions.footer" = "Vietos prieigą galėsite pakeisti vėliau iPhone nustatymuose.";
