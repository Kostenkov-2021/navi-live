"onboarding.title" = "Bienvenue au Navi Live";
"onboarding.section.intro" = "Petit guide";
"onboarding.intro" = "Navi Live est une application accessible de navigation à pied. Ce tutoriel présente le parcours de base : rechercher une destination, vérifier l'itinéraire, puis suivre le guidage vocal en marchant.";
"onboarding.section.features" = "Flux de base";
"onboarding.feature.search" = "Utilisez « Rechercher une destination » et saisissez une adresse ou un lieu. Lorsque Navi Live connaît votre position, les points proches sont affichés en premier.";
"onboarding.feature.route" = "Vérifiez l'aperçu de l'itinéraire avant de marcher et assurez-vous que la liste d'instructions a du sens.";
"onboarding.feature.navigation" = "Démarrez le guidage et écoutez les comptes à rebours de distance, les virages, les alertes de passage à niveau, les sons et les vibrations.";
"onboarding.section.on_route" = "En route";
"onboarding.feature.actions" = "Ouvrez les paramètres depuis n'importe quel écran, utilisez les actions du rotor VoiceOver à certains endroits et secouez le téléphone pour répéter l'instruction en cours.";
"onboarding.feature.accessibility" = "Utilisez les commandes natives de l’iPhone conçues pour une mise au point VoiceOver fiable.";
"onboarding.feature.favorites" = "Enregistrez la position actuelle sous votre propre nom et revenez-y plus tard à partir des Favoris.";
"onboarding.feature.safety" = "Les données GPS et cartographiques peuvent être imparfaites. Traitez le Navi Live comme support et vérifiez toujours les passages à niveau, la circulation et les environs.";
"onboarding.action.start" = "Continuer vers les autorisations";
"onboarding.footer" = "Vous pourrez rouvrir ce didacticiel ultérieurement à partir des paramètres.";
"permissions.title" = "Accès à la localisation";
"permissions.status.title" = "Autorisation de localisation requise";
"permissions.status.message" = "Autoriser l'accès à la localisation afin que Navi Live puisse trouver des lieux à proximité et préparer des itinéraires de randonnée à partir de votre position actuelle.";
"permissions.action.allow" = "Autoriser l'accès à la localisation";
"permissions.action.later" = "Continuer pour l'instant";
"permissions.footer" = "Vous pouvez modifier l'accès à la localisation ultérieurement dans les paramètres de l'iPhone.";
