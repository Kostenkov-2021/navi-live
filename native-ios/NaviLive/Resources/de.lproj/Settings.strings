"help.title" = "Hilfe und Datenschutz";
"help.section.tutorial" = "Tutorial";
"help.tutorial.body" = "Suchen Sie nach einem Ziel, überprüfen Sie die Routenvorschau und starten Sie dann die Fußführung. Während der Navigation können Sie von jedem Bildschirm aus die Einstellungen öffnen, Rotoraktionen auf Orte anwenden, Ihren aktuellen Standort als Favorit speichern und das Telefon schütteln, um die aktuelle Anweisung zu wiederholen.";
"help.section.visual_assistance" = "Visuelle Hilfe";
"help.visual_assistance.body" = "Wenn Sie während einer Route die Augen einer anderen Person benötigen, kann Navi Live Be My Eyes schnell öffnen. Verwenden Sie es, um eine Gebäudenummer, einen Eingang oder die richtige Taste der Gegensprechanlage zu finden.";
"help.visual_assistance.open" = "Öffnen Sie Be My Eyes";
"settings.support.section" = "Unterstützen Sie die Entwicklung";
"settings.support.body" = "Wenn Ihnen Navi Live gefällt und Sie seine Entwicklung unterstützen möchten, können Sie über PayPal einen Beitrag leisten. Jeder Beitrag trägt zur Finanzierung von Barrierefreiheitsarbeiten, Korrekturen und neuen Funktionen bei.";
"support.amounts.description" = "Wählen Sie schnell einen Betrag oder geben Sie Ihren eigenen ein. PayPal fordert den Benutzer weiterhin auf, die Zahlung zu bestätigen.";
"support.amount.button_format" = "%d PLN";
"support.amount.custom.title" = "Benutzerdefinierter Betrag";
"support.amount.custom.placeholder" = "Zum Beispiel 15";
"support.amount.custom.button" = "Unterstützung mit einem benutzerdefinierten Betrag";
"support.amount.custom.invalid" = "Geben Sie einen gültigen Betrag ein, zum Beispiel 15 oder 15,50.";
"support.amount.other_currency.button" = "Wählen Sie einen anderen Betrag oder eine andere Währung";
"support.amount.copy_link" = "Support-Link kopieren";
"support.amount.copy_success" = "Der PayPal-Support-Link befindet sich jetzt in der Zwischenablage.";
"help.section.privacy" = "Datenschutz";
"help.privacy.body" = "Navi Live speichert Favoriten und Führungseinstellungen auf dem Gerät. Suchen, umgekehrte Geokodierung und Routenvorbereitung nutzen Online-Dienste nur, wenn Sie danach fragen.";
