"onboarding.title" = "Willkommen bei Navi Live";
"onboarding.section.intro" = "Kurzanleitung";
"onboarding.intro" = "Navi Live ist eine barrierefreie Navigation zu Fuß. Dieses Tutorial zeigt den grundlegenden Ablauf: Suchen Sie nach einem Ziel, überprüfen Sie die Route und folgen Sie dann beim Gehen der gesprochenen Anleitung.";
"onboarding.section.features" = "Grundlegender Ablauf";
"onboarding.feature.search" = "Verwenden Sie „Ziel suchen“ und geben Sie eine Adresse oder einen Ort ein. Wenn Navi Live Ihren Standort hat, werden Punkte in der Nähe zuerst angezeigt.";
"onboarding.feature.route" = "Überprüfen Sie vor dem Gehen die Routenvorschau und stellen Sie sicher, dass die Anleitungsliste sinnvoll ist.";
"onboarding.feature.navigation" = "Starten Sie die Zielführung und achten Sie auf Distanz-Countdowns, Abbiegehinweise, Kreuzungswarnungen, Geräusche und Vibrationen.";
"onboarding.section.on_route" = "Unterwegs";
"onboarding.feature.actions" = "Öffnen Sie die Einstellungen auf einem beliebigen Bildschirm, verwenden Sie VoiceOver-Rotoraktionen an bestimmten Stellen und schütteln Sie das Telefon, um die aktuelle Anweisung zu wiederholen.";
"onboarding.feature.accessibility" = "Verwenden Sie native iPhone-Steuerelemente, die für einen zuverlässigen VoiceOver-Fokus entwickelt wurden.";
"onboarding.feature.favorites" = "Speichern Sie die aktuelle Position unter Ihrem eigenen Namen und kehren Sie später aus den Favoriten dorthin zurück.";
"onboarding.feature.safety" = "GPS- und Kartendaten können unvollständig sein. Behandeln Sie Navi Live als Unterstützung und überprüfen Sie stets Kreuzungen, Verkehr und Umgebung.";
"onboarding.action.start" = "Weiter zu Berechtigungen";
"onboarding.footer" = "Sie können dieses Tutorial später über die Einstellungen erneut öffnen.";
"permissions.title" = "Standortzugriff";
"permissions.status.title" = "Standortberechtigung erforderlich";
"permissions.status.message" = "Standortzugriff zulassen, damit Navi Live Orte in der Nähe finden und Wanderrouten von Ihrer aktuellen Position aus vorbereiten kann.";
"permissions.action.allow" = "Standortzugriff zulassen";
"permissions.action.later" = "Vorerst fortfahren";
"permissions.footer" = "Sie können den Standortzugriff später in den iPhone-Einstellungen ändern.";
