"help.section.privacy" = "Privasi";
"help.privacy.body" = "Navi Live menyimpan favorit dan preferensi panduan pada perangkat. Pencarian, geocoding balik, dan persiapan rute menggunakan layanan online hanya jika Anda memintanya.";
