"help.title" = "Bantuan dan privasi";
"help.section.tutorial" = "Tutorial";
"help.tutorial.body" = "Cari tujuan, periksa pratinjau rute, lalu mulai panduan berjalan. Selama navigasi, Anda dapat membuka Pengaturan dari layar mana pun, menggunakan tindakan rotor di tempat, menyimpan lokasi Anda saat ini sebagai favorit, dan menggoyangkan ponsel untuk mengulangi instruksi saat ini.";
"help.section.visual_assistance" = "Bantuan visual";
"help.visual_assistance.body" = "Ketika Anda membutuhkan mata orang lain selama perjalanan, Navi Live dapat dengan cepat membuka Be My Eyes. Gunakan untuk menemukan nomor gedung, pintu masuk, atau tombol interkom kanan.";
"help.visual_assistance.open" = "Buka Mataku";
"settings.support.section" = "Mendukung pengembangan";
"settings.support.body" = "Jika Anda menikmati Navi Live dan ingin mendukung pengembangannya, Anda dapat berkontribusi melalui PayPal. Setiap kontribusi membantu mendanai pekerjaan aksesibilitas, perbaikan, dan fitur baru.";
"support.amounts.description" = "Pilih jumlah cepat atau masukkan jumlah Anda sendiri. PayPal masih meminta pengguna untuk mengkonfirmasi pembayaran.";
