"onboarding.title" = "Selamat datang di Navi Live";
"onboarding.section.intro" = "Panduan singkat";
"onboarding.intro" = "Navi Live adalah navigasi berjalan kaki yang dapat diakses. Tutorial ini menunjukkan alur dasar: mencari tujuan, memeriksa rute, lalu mengikuti panduan lisan sambil berjalan.";
"onboarding.section.features" = "Aliran dasar";
"onboarding.feature.search" = "Gunakan Cari tujuan dan ketikkan alamat atau tempat. Jika Navi Live mengetahui lokasi Anda, titik terdekat akan ditampilkan terlebih dahulu.";
"onboarding.feature.route" = "Periksa pratinjau rute sebelum berjalan dan pastikan daftar instruksi masuk akal.";
"onboarding.feature.navigation" = "Mulai panduan dan dengarkan hitungan mundur jarak, belokan, peringatan penyeberangan, suara dan getaran.";
"onboarding.section.on_route" = "Dalam perjalanan";
"onboarding.feature.actions" = "Buka Pengaturan dari layar mana pun, gunakan tindakan rotor VoiceOver di beberapa tempat, dan goyangkan ponsel untuk mengulangi instruksi saat ini.";
"onboarding.feature.accessibility" = "Gunakan kontrol iPhone asli yang dirancang untuk fokus VoiceOver yang andal.";
"onboarding.feature.favorites" = "Simpan posisi saat ini atas nama Anda sendiri dan kembali lagi nanti dari Favorit.";
"onboarding.feature.safety" = "Data GPS dan peta mungkin tidak sempurna. Perlakukan Navi Live sebagai pendukung dan selalu verifikasi penyeberangan, lalu lintas dan lingkungan sekitar.";
"onboarding.action.start" = "Lanjutkan ke izin";
"onboarding.footer" = "Anda dapat membuka kembali tutorial ini nanti dari Pengaturan.";
"permissions.title" = "Akses lokasi";
"permissions.status.title" = "Diperlukan izin lokasi";
"permissions.status.message" = "Izinkan akses lokasi sehingga Navi Live dapat menemukan tempat terdekat dan menyiapkan rute berjalan kaki dari posisi Anda saat ini.";
"permissions.action.allow" = "Izinkan akses lokasi";
"permissions.action.later" = "Lanjutkan untuk saat ini";
"permissions.footer" = "Anda dapat mengubah akses lokasi nanti di Pengaturan iPhone.";
