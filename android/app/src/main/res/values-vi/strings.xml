    <string name="onboarding_title">Chào mừng bạn đến với Navi Live</string>
    <string name="onboarding_status_title">Hướng dẫn ngắn</string>
    <string name="onboarding_status_message">Tìm hiểu quy trình cơ bản: tìm kiếm điểm đến, kiểm tra lộ trình, sau đó làm theo hướng dẫn đi bộ bằng giọng nói.</string>
    <string name="onboarding_how_it_works_title">Luồng cơ bản</string>
    <string name="onboarding_search_label">Đích tìm kiếm</string>
    <string name="onboarding_search_message">Sử dụng Đích tìm kiếm và nhập địa chỉ hoặc địa điểm. Khi Navi Live có vị trí của bạn, các điểm lân cận sẽ được hiển thị đầu tiên.</string>
    <string name="onboarding_align_label">Kiểm tra tuyến đường</string>
    <string name="onboarding_align_message">Mở bản xem trước tuyến đường trước khi đi bộ. Danh sách hướng dẫn giúp bạn quyết định xem tuyến đường có hợp lý hay không.</string>
    <string name="onboarding_navigate_label">Đi bộ có hướng dẫn</string>
    <string name="onboarding_navigate_message">Sau khi bắt đầu điều hướng, hãy lắng nghe đếm ngược khoảng cách, hướng dẫn rẽ, cảnh báo băng qua đường, âm thanh và độ rung.</string>
    <string name="onboarding_expect_title">Hành động hữu ích và an toàn</string>
    <string name="onboarding_expect_message">Lưu vị trí hiện tại dưới tên của chính bạn, mở Cài đặt từ bất kỳ màn hình nào, sử dụng thao tác vuốt lên và xuống ở các địa điểm và lắc điện thoại để lặp lại hướng dẫn. Dữ liệu GPS và bản đồ có thể không hoàn hảo, vì vậy hãy luôn xác minh các điểm giao cắt và khu vực xung quanh.</string>
    <string name="onboarding_continue">Tiếp tục thiết lập</string>
    <string name="tutorial_navigation_title">Hướng dẫn</string>
    <string name="tutorial_status_title">Cách sử dụng Navi Live</string>
    <string name="tutorial_status_message">Xem lại quy trình hàng ngày: tìm kiếm, xem trước lộ trình, hướng dẫn trực tiếp và hành động nhanh.</string>
    <string name="tutorial_welcome_status_title">Hướng dẫn ngắn gọn</string>
    <string name="tutorial_welcome_status_message">Tìm hiểu quy trình cơ bản: tìm kiếm điểm đến, kiểm tra tuyến đường, sau đó làm theo hướng dẫn đi bộ bằng giọng nói.</string>
    <string name="tutorial_revisit_status_title">Cách sử dụng Navi Live</string>
    <string name="tutorial_revisit_status_message">Xem lại quy trình hàng ngày: tìm kiếm, xem trước lộ trình, hướng dẫn trực tiếp và hành động nhanh.</string>
    <string name="tutorial_flow_title">Luồng cơ bản</string>
    <string name="tutorial_search_label">Đích tìm kiếm</string>
    <string name="tutorial_search_message">Sử dụng Đích tìm kiếm và nhập địa chỉ hoặc địa điểm. Khi Navi Live có vị trí của bạn, các điểm lân cận sẽ được hiển thị đầu tiên.</string>
    <string name="tutorial_route_label">Kiểm tra tuyến đường</string>
    <string name="tutorial_route_message">Mở bản xem trước tuyến đường trước khi đi bộ. Danh sách hướng dẫn giúp bạn quyết định xem tuyến đường có hợp lý hay không.</string>
    <string name="tutorial_guidance_label">Đi bộ có hướng dẫn</string>
    <string name="tutorial_guidance_message">Sau khi bắt đầu điều hướng, hãy lắng nghe đếm ngược khoảng cách, hướng dẫn rẽ, cảnh báo băng qua đường, âm thanh và độ rung.</string>
    <string name="tutorial_tools_title">Đang di chuyển</string>
    <string name="tutorial_actions_label">Thao tác nhanh</string>
    <string name="tutorial_actions_message">Mở Cài đặt từ bất kỳ màn hình nào, sử dụng thao tác vuốt lên và xuống ở các địa điểm và lắc điện thoại để lặp lại hướng dẫn hiện tại.</string>
    <string name="tutorial_safety_label">An toàn</string>
    <string name="tutorial_safety_message">Dữ liệu bản đồ và GPS có thể không hoàn hảo. Hãy coi Navi Live là người hỗ trợ và luôn xác minh các lối đi qua, giao thông và khu vực xung quanh.</string>
