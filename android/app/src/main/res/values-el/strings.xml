    <string name="onboarding_status_message">Το Navi Live διατηρεί κάθε οθόνη εστιασμένη σε μια καθαρή ενέργεια με ισχυρή φωνή και απτική καθοδήγηση.</string>
    <string name="onboarding_how_it_works_title">Πώς λειτουργεί αυτή η κατασκευή</string>
    <string name="onboarding_search_label">Ερευνα</string>
    <string name="onboarding_search_message">Βρείτε μια διεύθυνση ή ένα μέρος και, στη συνέχεια, επιβεβαιώστε τη σύνοψη της διαδρομής.</string>
    <string name="onboarding_align_label">Εκκίνηση</string>
    <string name="onboarding_align_message">Ξεκινήστε την πλοήγηση και ξεκινήστε το περπάτημα. Το Navi Live θα καθορίσει την κατεύθυνση από την κίνησή σας.</string>
    <string name="onboarding_navigate_label">Διαπλέω</string>
    <string name="onboarding_navigate_message">Χρησιμοποιήστε προφορική καθοδήγηση, δόνηση και μεγάλες ενέργειες ενώ περπατάτε.</string>
    <string name="onboarding_expect_title">Τι να περιμένουμε</string>
    <string name="onboarding_expect_message">Αυτό το MVP χρησιμοποιεί διαδικτυακή αναζήτηση και δρομολόγηση. Η ζωντανή καθοδήγηση βελτιώνεται μόλις χορηγηθεί η άδεια τοποθεσίας.</string>
    <string name="onboarding_continue">Συνεχίστε τη ρύθμιση</string>
    <string name="tutorial_navigation_title">Φροντιστήριο</string>
    <string name="tutorial_status_title">Επισκεφτείτε ξανά το σεμινάριο ανά πάσα στιγμή</string>
    <string name="tutorial_status_message">Ελέγξτε την ίδια αναζήτηση, προεπισκόπηση διαδρομής και καθοδήγηση πεζοπορίας που χρησιμοποιείται κατά τη ρύθμιση.</string>
    <string name="tutorial_welcome_status_title">Σύντομος οδηγός</string>
    <string name="tutorial_welcome_status_message">Μάθετε τη βασική ροή: αναζητήστε έναν προορισμό, ελέγξτε τη διαδρομή και, στη συνέχεια, ακολουθήστε προφορική καθοδήγηση πεζοπορίας.</string>
    <string name="tutorial_revisit_status_title">Πώς να χρησιμοποιήσετε το Navi Live</string>
    <string name="tutorial_revisit_status_message">Ελέγξτε την καθημερινή ροή: αναζήτηση, προεπισκόπηση διαδρομής, ζωντανή καθοδήγηση και γρήγορες ενέργειες.</string>
    <string name="tutorial_flow_title">Βασική ροή</string>
    <string name="tutorial_search_label">Αναζήτηση προορισμού</string>
    <string name="tutorial_search_message">Χρησιμοποιήστε την Αναζήτηση προορισμού και πληκτρολογήστε μια διεύθυνση ή ένα μέρος. Όταν το Navi Live έχει την τοποθεσία σας, τα κοντινά σημεία εμφανίζονται πρώτα.</string>
    <string name="tutorial_route_label">Ελέγξτε τη διαδρομή</string>
    <string name="tutorial_route_message">Ανοίξτε την προεπισκόπηση διαδρομής πριν περπατήσετε. Η λίστα οδηγιών σάς βοηθά να αποφασίσετε εάν η διαδρομή έχει νόημα.</string>
    <string name="tutorial_guidance_label">Περπατήστε με καθοδήγηση</string>
    <string name="tutorial_guidance_message">Μετά την έναρξη της πλοήγησης, ακούστε για αντίστροφες μετρήσεις απόστασης, οδηγίες στροφής, ειδοποιήσεις διασταύρωσης, ήχους και δόνηση.</string>
    <string name="tutorial_tools_title">Στο δρόμο</string>
    <string name="tutorial_actions_label">Γρήγορες ενέργειες</string>
    <string name="tutorial_actions_message">Ανοίξτε τις Ρυθμίσεις από οποιαδήποτε οθόνη, χρησιμοποιήστε τις ενέργειες ολίσθησης προς τα επάνω και προς τα κάτω σε μέρη και ανακινήστε το τηλέφωνο για να επαναλάβετε την τρέχουσα οδηγία.</string>
    <string name="tutorial_safety_label">Ασφάλεια</string>
    <string name="tutorial_safety_message">Τα δεδομένα GPS και χάρτη μπορεί να είναι ατελή. Αντιμετωπίστε το Navi Live ως υποστήριξη και ελέγχετε πάντα τις διαβάσεις, την κυκλοφορία και το περιβάλλον.</string>
    <string name="tutorial_startup_section_title">Εκκίνηση</string>
